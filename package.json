{
  "name": "wealth-ui",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --names \"client,server\" --prefix-colors \"cyan,magenta\" \"yarn --cwd client dev\" \"yarn --cwd server dev\"",
    "build": "yarn --cwd client build",
    "start": "yarn --cwd server start",
    "prod": "yarn build && yarn start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
